Terminals unused in grammar

    AND
    OR
    NOT


Grammar

    0 $accept: program $end

    1 program: decl_list

    2 decl_list: decl_list decl
    3          | decl

    4 decl: func_decl
    5     | var_decl

    6 func_decl: INT IDENTIFIER LPAREN param_list RPAREN LBRACE stmt_list RBRACE
    7          | VOID IDENTIFIER LPAREN param_list RPAREN LBRACE stmt_list RBRACE
    8          | INT IDENTIFIER LPAREN RPAREN LBRACE stmt_list RBRACE

    9 param_list: param_list COMMA param
   10           | param

   11 param: INT IDENTIFIER
   12      | FLOAT_TYPE IDENTIFIER

   13 var_decl: INT IDENTIFIER SEMICOLON
   14         | INT IDENTIFIER ASSIGN expr SEMICOLON
   15         | FLOAT_TYPE IDENTIFIER ASSIGN expr SEMICOLON
   16         | FLOAT_TYPE IDENTIFIER SEMICOLON

   17 stmt_list: stmt_list stmt
   18          | %empty

   19 stmt: var_decl
   20     | assign_stmt
   21     | if_stmt
   22     | while_stmt
   23     | return_stmt
   24     | expr SEMICOLON

   25 assign_stmt: IDENTIFIER ASSIGN expr SEMICOLON

   26 if_stmt: IF LPAREN condition RPAREN LBRACE stmt_list RBRACE ELSE LBRACE stmt_list RBRACE
   27        | IF LPAREN condition RPAREN LBRACE stmt_list RBRACE

   28 while_stmt: WHILE LPAREN condition RPAREN LBRACE stmt_list RBRACE

   29 return_stmt: RETURN expr SEMICOLON
   30            | RETURN SEMICOLON

   31 condition: expr LT expr
   32          | expr GT expr
   33          | expr EQ expr
   34          | expr NEQ expr
   35          | expr LEQ expr
   36          | expr GEQ expr

   37 expr: expr PLUS term
   38     | expr MINUS term
   39     | term

   40 term: term MULTIPLY factor
   41     | term DIVIDE factor
   42     | factor

   43 factor: NUMBER
   44       | FLOAT_NUM
   45       | IDENTIFIER
   46       | LPAREN expr RPAREN
   47       | MINUS factor


